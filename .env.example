# Local Development
# PORT=5000
# MONGODB_URI=mongodb://127.0.0.1:27017/web_app
# JWT_SECRET=dev_secret_change_me
# CLIENT_URL=http://localhost:5173

# Production (use these for Render deployment)
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/web_app?retryWrites=true&w=majority
JWT_SECRET=your_super_secure_random_jwt_secret_here_min_32_chars
CLIENT_URL=https://your-vercel-frontend-url.vercel.app
# Optional: support multiple origins (comma separated), e.g. production + preview domain
# CLIENT_URLS=https://your-vercel-frontend-url.vercel.app,https://your-other-domain.com
